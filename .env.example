# ═══════════════════════════════════════════════════════════════════════════════
# LunchApp — Configuration d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ── Serveur ────────────────────────────────────────────────────────────────────
PORT=3000
APP_URL=https://votre-projet.vercel.app

# ── JWT (changez en production !) ──────────────────────────────────────────────
# Générez une clé aléatoire : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ── Superadmin ─────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@lunchapp.com
ADMIN_PASSWORD=ChangeMe!
ADMIN_FULLNAME=Super Administrateur

# ── Email (Gmail) — optionnel ─────────────────────────────────────────────────
# Sans ces valeurs, l'envoi d'emails est désactivé
# Créez un mot de passe d'application Google : https://myaccount.google.com/apppasswords
MAIL_USER=
MAIL_PASS=
MAIL_FROM=LunchApp <noreply@lunchapp.com>

# ── Supabase (PostgreSQL) — requis pour Vercel ────────────────────────────────
# 1. Créez un projet sur https://supabase.com
# 2. Allez dans Settings → Database → Connection string → URI
# 3. Copiez la chaîne et collez-la ci-dessous
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DB_SSL=true

# ── WhatsApp Worker (optionnel) ────────────────────────────────────────────────
WA_SENDER=22664046120
